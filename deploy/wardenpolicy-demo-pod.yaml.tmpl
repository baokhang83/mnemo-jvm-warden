# W-306 end-to-end demo fixture, templated with envsubst by deploy/verify-wardenpolicy-intent.sh
# (never applied directly): a real target JVM + Warden sidecar, sized and configured identically
# to W-206's proven-working "idle load" scenario (deploy/oomkill-safety-check.yaml.tmpl) — same
# -Xmx, same RETAIN_MB, same shrink target — to avoid re-debugging G1 heap sizing already solved
# there. The only new thing here is that the resize is driven by a real WardenPolicy schedule
# through the real controller + agent intent handoff, not a kubectl-exec'd test driver.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: warden-demo-e2e
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: warden-demo-e2e-resize
rules:
  - apiGroups: [""]
    resources: ["pods/resize"]
    resourceNames: ["warden-demo-e2e"]
    verbs: ["patch"]
  - apiGroups: [""]
    resources: ["pods"]
    resourceNames: ["warden-demo-e2e"]
    verbs: ["get"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: warden-demo-e2e-resize
subjects:
  - kind: ServiceAccount
    name: warden-demo-e2e
roleRef:
  kind: Role
  name: warden-demo-e2e-resize
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: v1
kind: Pod
metadata:
  name: warden-demo-e2e
  labels:
    app.kubernetes.io/name: warden-demo-e2e
spec:
  serviceAccountName: warden-demo-e2e
  shareProcessNamespace: true
  volumes:
    - name: host-cgroup
      hostPath:
        path: /sys/fs/cgroup
        type: Directory

  initContainers:
    - name: warden
      image: ${WARDEN_IMAGE}
      imagePullPolicy: IfNotPresent
      restartPolicy: Always # native sidecar
      ports:
        - name: health
          containerPort: 8080
      env:
        - name: WARDEN_POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        - name: WARDEN_TARGET_CONTAINER_NAME
          value: app
        # Faster than the 5s default so the demo doesn't need a long wait to observe the resize.
        - name: WARDEN_INTENT_POLL_INTERVAL_SECONDS
          value: "2"
      volumeMounts:
        - name: host-cgroup
          mountPath: /host-cgroup
          readOnly: true
      livenessProbe:
        httpGet:
          path: /healthz
          port: health
        periodSeconds: 10
      readinessProbe:
        httpGet:
          path: /readyz
          port: health
        periodSeconds: 5
      resources:
        requests:
          cpu: 25m
          memory: 64Mi
        limits:
          memory: 256Mi

  containers:
    - name: app
      image: ${WARDEN_IMAGE}
      imagePullPolicy: IfNotPresent
      command:
        - java
        - -XX:+UseG1GC
        - -Xmx350m
        - -Dcom.sun.management.jmxremote.port=9999
        - -Dcom.sun.management.jmxremote.rmi.port=9999
        - -Dcom.sun.management.jmxremote.host=127.0.0.1
        - -Dcom.sun.management.jmxremote.authenticate=false
        - -Dcom.sun.management.jmxremote.ssl=false
        - -Djava.rmi.server.hostname=127.0.0.1
        - -cp
        - /app/warden-agent.jar
        - io.github.baokhang83.mnemo.warden.agent.harness.LoadTarget
      env:
        - name: WARDEN_LOAD_TARGET_RETAIN_MB
          value: "10" # idle load — the same value W-206 already proved shrinks safely to 150Mi
      resources:
        requests:
          cpu: 100m
          memory: 400Mi
        limits:
          memory: 450Mi
      resizePolicy:
        - resourceName: memory
          restartPolicy: NotRequired
